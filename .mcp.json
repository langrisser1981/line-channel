{
  "mcpServers": {
    "line-channel": {
      "command": "bun",
      "args": ["./src/index.ts"],
      "env": {
        "LINE_CHANNEL_ACCESS_TOKEN": "${LINE_CHANNEL_ACCESS_TOKEN}",
        "LINE_CHANNEL_SECRET": "${LINE_CHANNEL_SECRET}",
        "LINE_USER_ID": "${LINE_USER_ID}",
        "LINE_WEBHOOK_PORT": "${LINE_WEBHOOK_PORT}"
      }
    }
  }
}
